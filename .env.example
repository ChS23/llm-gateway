OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Bootstrap admin API key — auto-inserted into DB on startup
ADMIN_API_KEY=

# Encryption key for provider API keys at rest (base64-encoded 32 bytes)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Langfuse Cloud — base64(public_key:secret_key)
LANGFUSE_BASEURL=https://cloud.langfuse.com
LANGFUSE_AUTH=
